# SeeSharp concrete development environment defaults
# Loaded automatically by Program.cs in development mode.

# LM Studio API key (LM Studio typically accepts this default token)
LMSTUDIO_API_KEY=lm-studio

# Contextualizer model used for repo summarization
SEESHARP_CONTEXTUALIZER_MODEL=qwen/qwen3.5-2b

# Stream main model tokens live to console during tool loop
SEESHARP_STREAM_MAIN_MODEL=1

# Keep rich console output in dev
SEESHARP_PLAIN=0
NO_COLOR=0

# Optional switches (uncomment if needed)
# SEESHARP_DISABLE_WATCH=1
# SEESHARP_LEGACY=1
# HARNESS_WORKSPACE_ROOT=.
