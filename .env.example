# SeeSharp environment template (.NET CLI / .NET 10)
# Copy to `.env` (local only) or set these in your shell before running.
#
# PowerShell example:
#   Get-Content .env | ForEach-Object {
#     if ($_ -match '^\s*#' -or $_ -match '^\s*$') { return }
#     $name, $value = $_ -split '=', 2
#     [System.Environment]::SetEnvironmentVariable($name.Trim(), $value.Trim(), 'Process')
#   }

# REQUIRED (runtime)
# LM Studio API key for OpenAI-compatible endpoint. If unset, app defaults to "lm-studio".
LMSTUDIO_API_KEY=lm-studio

# RECOMMENDED
# Model ID used by contextualizer chat client.
# If unset, defaults to Agent.DefaultContextualizerModelId.
SEESHARP_CONTEXTUALIZER_MODEL=qwen/qwen3.5-2b

# OPTIONAL (agent UX)
# Stream main-model tokens live in tool loop.
# 1=true, 0/false/off=false. If unset, defaults to enabled in code.
SEESHARP_STREAM_MAIN_MODEL=1

# OPTIONAL (workspace/pathing)
# Workspace root for file resolution/contextualizer indexing.
# If unset, app discovers from .csproj / current directory.
# HARNESS_WORKSPACE_ROOT=C:\projects\jmartinez\seesharp

# OPTIONAL (dev runner)
# Disable auto relaunch under dotnet watch in legacy mode.
# 1=true
# SEESHARP_DISABLE_WATCH=1

# Force legacy all-model harness path.
# 1=true
# SEESHARP_LEGACY=0

# OPTIONAL (console formatting)
# Plain output mode (reduced styling)
# 1=true
# SEESHARP_PLAIN=0

# Disable ANSI coloring entirely
# 1=true
# NO_COLOR=0

# NOTE:
# DOTNET_WATCH and DOTNET_WATCH_ITERATION are managed by `dotnet watch`.
# You do not set them manually.
